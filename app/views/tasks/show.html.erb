<div class="max-w-5xl mx-auto mt-6">
  
  <div class="flex justify-between items-center mb-6">
    <%= link_to project_path(@project), class: "text-gray-500 hover:text-gray-900 flex items-center text-sm font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to Project
    <% end %>

    <%= link_to edit_project_task_path(@project, @task), class: "text-blue-600 hover:text-blue-800 flex items-center text-sm font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
      </svg>
      Edit Task
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-1 gap-8">
    
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8">
        <div class="px-6 py-5 bg-white border-b border-gray-100 flex justify-between items-start">
          <h1 class="text-2xl font-bold text-gray-900"><%= @task.title %></h1>
          
          <% status_colors = case @task.status
             when 'done' then 'bg-green-100 text-green-800'
             when 'in_progress' then 'bg-blue-100 text-blue-800'
             else 'bg-gray-100 text-gray-800'
             end %>
          <span class="<%= status_colors %> px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide">
            <%= @task.status.humanize %>
          </span>
        </div>

        <div class="px-6 py-3 bg-gray-50 border-b border-gray-100 flex flex-wrap gap-6 text-xs text-gray-500 font-medium">
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1.5 text-gray-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
            </svg>
            <%= link_to @project.title, project_path(@project), class: "hover:text-blue-600 underline decoration-gray-300 underline-offset-2" %>
          </div>
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1.5 text-gray-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= @task.created_at.strftime("%B %d, %Y") %>
          </div>
        </div>

        <div class="p-6">
          <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-3">Description</h3>
          <div class="prose prose-sm text-gray-600 bg-gray-50/50 p-4 rounded-lg border border-gray-100">
            <% if @task.description.present? %>
              <%= simple_format @task.description %>
            <% else %>
              <em class="text-gray-400">No description provided.</em>
            <% end %>
          </div>

          <div class="mt-6 flex items-center justify-between">
            <div class="flex flex-wrap gap-2">
              <% @task.tags.each do |tag| %>
                <a href="<%= tag_path(tag) %>" class="text-xs font-bold text-white px-2 py-1 rounded shadow-sm hover:opacity-90 transition-opacity" style="background-color: <%= tag.tag_color %>">
                  <%= tag.name %>
                </a>
              <% end %>
            </div>
            
            <div class="text-xs font-bold text-gray-500 uppercase flex items-center">
              Priority: <span class="ml-2 bg-gray-100 text-gray-800 px-2 py-1 rounded border border-gray-200"><%= @task.priority %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 sticky top-6">
        <%= render 'shared/comments', commentable: @task %>
      </div>
    </div>

  </div>
</div>