<%= form_with(model: [@project, task], local: true, class: "space-y-6") do |form| %>
  
  <% if task.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative mb-4">
      <h4 class="font-bold"><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h4>
      <ul class="list-disc list-inside mt-1 text-sm">
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.text_field :title, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2", required: true %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 3, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2", required: true %>
  </div>

  <div>
    <%= form.label :priority, class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.select :priority, Task.priorities.keys.map { |w| [w.humanize, w] }, {}, { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-2" } %>
  </div>

  <% unless task.new_record? %>
    <div>
      <%= form.label :status, class: "block text-sm font-bold text-gray-700 mb-1" %>
      <%= form.select :status, Task.statuses.keys.map { |w| [w.humanize, w] }, {}, { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-2" } %>
    </div>
  <% end %>

  <div class="pt-2">
    <label class="block text-sm font-bold text-gray-700 mb-2">Tags</label>
    <div class="flex flex-wrap gap-4 p-4 bg-gray-50 rounded-md border border-gray-200">
      <%= form.collection_check_boxes :tag_ids, Tag.all, :id, :name do |b| %>
        <div class="flex items-center">
          <%= b.check_box(class: "h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500") %>
          <%= b.label(class: "ml-2 text-sm text-gray-700 font-medium") %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-6 border-t border-gray-100 mt-4">
    <%= link_to "Cancel", project_path(@project), class: "text-sm text-gray-500 hover:text-gray-900 font-medium" %>
    <%= form.submit class: "cursor-pointer bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-6 rounded-md shadow hover:shadow-lg transition duration-200" %>
  </div>

<% end %>