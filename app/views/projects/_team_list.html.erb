<div class="team-card">
  <div class="team-card-header">
    <h5 class="team-card-title">Team Members</h5>
  </div>
  
  <ul class="team-list">
    <% project.assignments.includes(:user).each do |assignment| %>
      <li class="team-list-item">
        <div>
          <strong><%= link_to assignment.user.first_name, user_dashboard_path(assignment.user), class: "team-member-link" %></strong>
          <span class="team-member-role">- <%= assignment.role %></span>
        </div>
        <small class="team-member-manager">
          Reports to: <%= assignment.user.manager&.first_name || "CEO" %>
        </small>
      </li>
    <% end %>
  </ul>

  <div class="team-card-footer">
    <strong class="team-card-footer-label">Add Member:</strong>
    
    <%= form_with(model: [project, Assignment.new], class: "team-form", local: true) do |form| %>
      
      <div class="team-form-field">
        <%= form.collection_select :user_id, @available_users, :id, :email, { prompt: "Select User..." }, { class: "team-form-select" } %>
      </div>

      <div class="team-form-field">
        <%= form.text_field :role, placeholder: "Role (e.g. Dev)", class: "team-form-input" %>
      </div>

      <div class="team-form-field">
        <%= form.button class: "btn-team-add" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="btn-team-add-icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Add to Team
        <% end %>
      </div>

    <% end %>
  </div>
</div>