<div class="flex justify-between items-center mb-6">
  <h3 class="text-2xl font-bold text-gray-800">Tasks</h3>
  <%= link_to new_project_task_path(project), class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg shadow transition duration-150 ease-in-out flex items-center" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Add Task
  <% end %>
</div>

<div class="space-y-4">
  <% tasks.each do |task| %>
    <% opacity = task.done? ? "opacity-60" : "opacity-100" %>
    <% decoration = task.done? ? "line-through text-gray-500" : "text-gray-900" %>
    <% border_color = task.done? ? "border-green-500" : "border-gray-300" %>
    
    <div class="<%= opacity %> bg-white border-l-4 <%= border_color %> shadow-sm rounded-r-lg p-5 hover:shadow-md transition-shadow duration-200">
      <div class="flex justify-between items-start">
        <div class="flex-1">
          <h5 class="text-lg font-semibold mb-2 <%= decoration %>">
            <%= link_to task.title, project_task_path(project, task), class: "hover:text-blue-600 transition-colors" %>
          </h5>
          
          <div class="flex flex-wrap gap-2 mb-2">
            <% task.tags.each do |tag| %>
              <span class="text-xs font-bold text-white px-2 py-1 rounded" style="background-color: <%= tag.tag_color %>">
                <%= tag.name %>
              </span>
            <% end %>
            <span class="text-xs font-bold bg-gray-100 text-gray-700 border border-gray-200 px-2 py-1 rounded uppercase">
              <%= task.priority %>
            </span>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <% if task.backlog? %>
            <%= button_to "Start", update_status_project_task_path(project, task, status: :in_progress), method: :patch, class: "text-xs font-medium bg-white border border-blue-500 text-blue-600 hover:bg-blue-50 px-3 py-1 rounded transition-colors" %>
          <% elsif task.in_progress? %>
            <%= button_to "Done", update_status_project_task_path(project, task, status: :done), method: :patch, class: "text-xs font-medium bg-green-500 text-white hover:bg-green-600 px-3 py-1 rounded shadow-sm transition-colors" %>
          <% end %>

          <%= link_to edit_project_task_path(project, task), class: "text-gray-400 hover:text-blue-500 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
          <% end %>
          
          <%= link_to project_task_path(project, task), data: { turbo_method: :delete, turbo_confirm: "Delete?" }, class: "text-gray-400 hover:text-red-500 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-6">
  <%= will_paginate tasks %>
</div>