<%= form_with(model: project, class: "space-y-6") do |form| %>
  <% if project.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative" role="alert">
      <h4 class="font-bold"><%= pluralize(project.errors.count, "error") %> prohibited this project from being saved:</h4>
      <ul class="list-disc list-inside mt-2">
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.text_field :title, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 3, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :status, class: "block text-sm font-bold text-gray-700 mb-1" %>
      <%= form.select :status, Project.statuses.keys.map { |w| [w.humanize, w] }, {}, { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-2" } %>
    </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :start_date, class: "block text-sm font-bold text-gray-700 mb-1" %>
      <% if project.new_record? %>
      <%= form.date_field :start_date, 
          value: Date.today, 
          readonly: true,
          class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2 bg-gray-100 text-gray-500 cursor-not-allowed" %>
    <% else %>
      <%= form.date_field :start_date, 
          min: project.start_date, 
          class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2" %>
    <% end %>
    </div>
    <div>
      <%= form.label :due_date, class: "block text-sm font-bold text-gray-700 mb-1" %>
      <%= form.date_field :due_date, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-4 py-2" %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-6 border-t border-gray-100 mt-4">
    <%= link_to "Cancel", projects_path, class: "text-sm text-gray-500 hover:text-gray-900 font-medium" %>
    <%= form.submit class: "cursor-pointer bg-slate-900 hover:bg-slate-800 text-white font-bold py-2 px-6 rounded-md shadow hover:shadow-lg transition duration-200" %>
  </div>
<% end %>