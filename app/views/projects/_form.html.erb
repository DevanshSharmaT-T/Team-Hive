<%= form_with(model: project, class: "space-y-6") do |form| %>
  <% if project.errors.any? %>
    <div class="form-error-box" role="alert">
      <h4 class="form-error-title"><%= pluralize(project.errors.count, "error") %> prohibited this project from being saved:</h4>
      <ul class="form-error-list">
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-input" %>
  </div>

  <div>
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, rows: 3, class: "form-input" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :status, class: "form-label" %>
      <%= form.select :status, Project.statuses.keys.map { |w| [w.humanize, w] }, {}, { class: "form-select" } %>
    </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :start_date, class: "form-label" %>
      <% if project.new_record? %>
      <%= form.date_field :start_date, 
          value: Date.today, 
          readonly: true,
          class: "form-input--disabled" %>
    <% else %>
      <%= form.date_field :start_date, 
          min: project.start_date, 
          class: "form-input" %>
    <% end %>
    </div>
    <div>
      <%= form.label :due_date, class: "form-label" %>
      <%= form.date_field :due_date, class: "form-input" %>
    </div>
  </div>

  <div class="form-footer">
    <%= link_to "Cancel", projects_path, class: "form-cancel-link" %>
    <%= form.submit class: "btn-submit" %>
  </div>
<% end %>