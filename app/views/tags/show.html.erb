<div class="max-w-4xl mx-auto py-8">
  
  <div class="tag-header" style="border-color: <%= @tag.tag_color %>;">
    <div>
      <h1 class="tag-title">
        <span class="text-white px-4 py-1 rounded-lg mr-3 shadow-md" style="background-color: <%= @tag.tag_color %>;">
          <%= @tag.name %>
        </span>
        <span class="text-gray-400 font-light text-2xl">Explorer</span>
      </h1>
    </div>
    <div class="tag-count">
      Found <strong><%= @tasks.count %></strong> tasks
    </div>
  </div>

  <% if @tasks.any? %>
    <div class="tag-task-list">
      <% @tasks.each do |task| %>
        <% border_color = task.done? ? "border-green-500" : "border-gray-300" %>
        
        <div class="tag-task-item border-l-4 <%= border_color %>">
          <div class="tag-task-header">
            <div>
              <h3 class="tag-task-title">
                <%= link_to task.title, project_task_path(task.project, task), class: "project-link" %>
              </h3>
              <div class="tag-task-project">
                in Project: 
                <%= link_to task.project.title, project_path(task.project), class: "tag-task-project-link" %>
              </div>
            </div>
            
            <div class="tag-task-badges">
               <span class="badge--inline"><%= task.status.humanize %></span>
               <span class="badge--inline"><%= task.priority %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="tag-empty">
      <p class="tag-empty-text">No tasks found with this tag.</p>
    </div>
  <% end %>

  <div class="tag-back-link">
    <%= link_to projects_path, class: "btn-secondary" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="btn-secondary-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to Projects
    <% end %>
  </div>

</div>