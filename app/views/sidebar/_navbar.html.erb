                  <div class="text-xs text-gray-400">Create a new account</div>
                <% end %>
                
                <div class="border-t border-gray-100 my-1"></div>

                <%= link_to new_user_session_path, class: "block px-4 py-2 text-sm hover:bg-blue-50 text-gray-700 hover:text-blue-700 transition-colors whitespace-nowrap" do %>
