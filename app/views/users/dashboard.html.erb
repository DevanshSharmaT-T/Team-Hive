<div class="max-w-6xl mx-auto py-6">
  
  <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-gray-200 pb-6 mb-8">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
        <%= @user.first_name %> <%= @user.last_name %>
      </h1>
      <p class="mt-1 text-sm text-gray-500 font-medium flex items-center">
        <%= @user.job_title %> <span class="mx-2 text-gray-300">|</span> <%= @user.email %>
      </p>
    </div>
    <div class="mt-4 md:mt-0">
      <%= link_to edit_user_path(@user), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
        </svg>
        Edit Profile
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center">
        <div class="bg-white p-1.5 rounded-lg shadow-sm mr-3 text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5M12 6.75h1.5M15 6.75h1.5M9 10.5h1.5M12 10.5h1.5M15 10.5h1.5M9 14.25h1.5M12 14.25h1.5M15 14.25h1.5M9 18h1.5M12 18h1.5M15 18h1.5" />
            </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-800">Organization</h3>
      </div>
      
      <div class="p-6 space-y-6">
        <div>
          <span class="text-xs font-bold text-gray-400 uppercase tracking-wider block mb-2">Reports To</span>
          <% if @manager %>
            <div class="flex items-center p-3 bg-blue-50 rounded-lg border border-blue-100">
              <div class="h-10 w-10 rounded-full bg-blue-200 flex items-center justify-center text-blue-700 font-bold text-sm mr-3">
                <%= @manager.first_name[0] %>
              </div>
              <div>
                <%= link_to @manager.first_name, user_dashboard_path(@manager), class: "text-blue-700 font-bold hover:underline" %> 
                <span class="block text-xs text-blue-500"><%= @manager.job_title %></span>
              </div>
            </div>
          <% else %>
            <div class="p-3 bg-gray-50 rounded-lg border border-gray-100 text-gray-500 text-sm italic">
              No Manager (Top Level Executive)
            </div>
          <% end %>
        </div>

        <div>
          <span class="text-xs font-bold text-gray-400 uppercase tracking-wider block mb-2">
            Direct Reports (<%= @subordinates.count %>)
          </span>
          <% if @subordinates.any? %>
            <ul class="divide-y divide-gray-100">
              <% @subordinates.each do |sub| %>
                <li class="py-3 flex items-center hover:bg-gray-50 rounded px-2 transition-colors">
                  <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs mr-3">
                    <%= sub.first_name[0] %>
                  </div>
                  <div class="flex-1">
                    <%= link_to sub.first_name, user_dashboard_path(sub), class: "text-gray-900 font-medium hover:text-blue-600" %>
                    <span class="ml-2 text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full"><%= sub.job_title %></span>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-300">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-gray-400 italic pl-2">No direct reports.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 bg-blue-50 border-b border-blue-100 flex items-center">
        <div class="bg-white p-1.5 rounded-lg shadow-sm mr-3 text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
            </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-800">Active Projects</h3>
      </div>
      
      <div class="p-6">
        <% if @projects.any? %>
          <div class="space-y-4">
            <% @projects.each do |project| %>
              <div class="group relative bg-white p-4 rounded-lg border border-gray-200 shadow-sm hover:shadow-md hover:border-blue-300 transition-all">
                <div class="flex justify-between items-start">
                  <div>
                    <h4 class="text-base font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                      <%= link_to project.title, project_path(project) %>
                      <span class="absolute inset-0"></span>
                    </h4>
                    <p class="text-xs text-gray-500 mt-1">Status: <%= project.status.humanize %></p>
                  </div>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    <%= project.assignments.find_by(user: @user)&.role || "Member" %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-10 bg-gray-50 rounded-lg border border-dashed border-gray-300">
            <p class="text-gray-500 text-sm">Not assigned to any projects yet.</p>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>