<div class="max-w-6xl mx-auto py-6">
  
  <div class="user-header">
    <div>
      <h1 class="user-name">
        <%= @user.first_name %> <%= @user.last_name %>
      </h1>
      <p class="user-subtitle">
        <%= @user.job_title %> <span class="user-subtitle-divider">|</span> <%= @user.email %>
      </p>
    </div>
    <div class="user-edit-btn">
      <%= link_to edit_user_path(@user), class: "user-edit-link" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="user-edit-icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
        </svg>
        Edit Profile
      <% end %>
    </div>
  </div>

  <div class="dashboard-grid">
    
    <div class="card">
      <div class="card-header">
        <div class="card-header-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="card-header-icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5M12 6.75h1.5M15 6.75h1.5M9 10.5h1.5M12 10.5h1.5M15 10.5h1.5M9 14.25h1.5M12 14.25h1.5M15 14.25h1.5M9 18h1.5M12 18h1.5M15 18h1.5" />
            </svg>
        </div>
        <h3 class="card-header-title">Organization</h3>
      </div>
      
      <div class="card-body space-y-6">
        <div>
          <span class="reports-to-label">Reports To</span>
          <% if @manager %>
            <div class="manager-card">
              <div class="user-avatar-md mr-3">
                <%= @manager.first_name[0] %>
              </div>
              <div>
                <%= link_to @manager.first_name, user_dashboard_path(@manager), class: "manager-link" %> 
                <span class="manager-title"><%= @manager.job_title %></span>
              </div>
            </div>
          <% else %>
            <div class="no-manager">
              No Manager (Top Level Executive)
            </div>
          <% end %>
        </div>

        <div>
          <span class="reports-to-label">
            Direct Reports (<%= @subordinates.count %>)
          </span>
          <% if @subordinates.any? %>
            <ul class="divide-y divide-gray-100">
              <% @subordinates.each do |sub| %>
                <li class="subordinate-item">
                  <div class="user-avatar-sm mr-3">
                    <%= sub.first_name[0] %>
                  </div>
                  <div class="subordinate-info">
                    <%= link_to sub.first_name, user_dashboard_path(sub), class: "subordinate-link" %>
                    <span class="badge--chip"><%= sub.job_title %></span>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="subordinate-chevron">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="no-reports">No direct reports.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header--blue">
        <div class="card-header-icon-wrap--blue">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="card-header-icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
            </svg>
        </div>
        <h3 class="card-header-title">Active Projects</h3>
      </div>
      
      <div class="card-body">
        <% if @projects.any? %>
          <div class="space-y-4">
            <% @projects.each do |project| %>
              <div class="project-item">
                <div class="project-item-header">
                  <div>
                    <h4 class="project-item-title">
                      <%= link_to project.title, project_path(project) %>
                      <span class="project-item-overlay"></span>
                    </h4>
                    <p class="project-item-status">Status: <%= project.status.humanize %></p>
                  </div>
                  <span class="badge--role">
                    <%= project.assignments.find_by(user: @user)&.role || "Member" %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="projects-empty">
            <p class="projects-empty-text">Not assigned to any projects yet.</p>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>