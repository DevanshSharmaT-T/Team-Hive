<div class="max-w-xl mx-auto mt-10">
  
  <div class="page-card">
    <div class="page-card-header">
      <h2 class="page-card-header-title">Edit Profile</h2>
      <p class="text-blue-200 text-sm">Update details for <%= @user.email %></p>
    </div>

    <div class="page-card-body">
      <%= form_with(model: @user, local: true, class: "space-y-6") do |form| %>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :first_name, class: "form-label" %>
            <%= form.text_field :first_name, class: "form-input" %>
          </div>

          <div>
            <%= form.label :last_name, class: "form-label" %>
            <%= form.text_field :last_name, class: "form-input" %>
          </div>
        </div>

        <div>
          <%= form.label :job_title, class: "form-label" %>
          <%= form.text_field :job_title, class: "form-input" %>
        </div>

        <div class="form-info-box">
          <%= form.label :manager_id, "Reports To (Manager)", class: "form-info-label" %>
          <p class="form-info-hint">Select the user who manages this employee.</p>
          
          <%= form.collection_select :manager_id, @potential_managers, :id, :email, 
              { include_blank: "No Manager (CEO)" }, 
              { class: "form-select" } %>
        </div>

        <div class="form-footer">
          <%= link_to "Cancel", user_dashboard_path(@user), class: "form-cancel-link" %>
          
          <%= form.submit "Update Profile", class: "btn-submit" %>
        </div>
      <% end %>
    </div>
  </div>
</div>