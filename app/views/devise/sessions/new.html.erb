<div class="auth-container">
  <div class="auth-card" style="width: 700px;">

    <h2 class="auth-title">
      Log in
    </h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "Enter your email",
                class: "form-input--auth" %>
        </div>

        <div class="auth-field">
          <%= f.label :password, class: "auth-label" %>
          <%= f.password_field :password,
                autocomplete: "current-password",
                placeholder: "Enter your password",
                class: "form-input--auth" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="auth-remember">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, class: "auth-remember-label" %>
          </div>
        <% end %>

        <div>
          <%= f.submit "Log in", class: "btn-auth-submit" %>
        </div>

      <% end %>

      <div class="auth-links">
        <%= render "devise/shared/links" %>
      </div>

    </div>
  </div>
