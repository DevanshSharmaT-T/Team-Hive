<div class="signup-container">
  <div class="auth-card max-w-md w-full">
    
    <h2 class="auth-title--signup">
      Create your account
    </h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      
      <% if resource.errors.any? %>
        <div class="signup-error">
          <div class="signup-error-inner">
            <div class="signup-error-icon-wrap">
              <svg class="signup-error-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="signup-error-body">
              <h3 class="signup-error-title">
                <%= pluralize(resource.errors.count, "error") %> prohibited this account from being saved:
              </h3>
              <ul class="signup-error-list">
                <% resource.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, class: "auth-label" %>
          <%= f.text_field :first_name, autofocus: true, class: "form-input--auth" %>
        </div>
        <div>
          <%= f.label :last_name, class: "auth-label" %>
          <%= f.text_field :last_name, class: "form-input--auth" %>
        </div>
      </div>

      <div>
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "form-input--auth" %>
      </div>

      <div>
        <%= f.label :password, class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input--auth" %>
        <% if @minimum_password_length %>
          <p class="signup-hint">Must be at least <%= @minimum_password_length %> characters.</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm Password", class: "auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input--auth" %>
      </div>
      <br>
      <div>
        <%= f.submit "Sign up", class: "btn-auth-submit" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>


  </div>
</div>