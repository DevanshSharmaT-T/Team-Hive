<div class=" flex items-center justify-center ">
  <div class="bg-white p-8 rounded-2xl shadow-lg" style="width: 700px;">

    
    <h2 class="text-3xl font-bold text-gray-800 text-center mb-6">
      Create your account
    </h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "Enter an email (example@example.com)",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-semibold text-gray-700 mb-1" %>

        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mb-1">(<%= @minimum_password_length %> characters minimum)</p>
        <% end %>

        <%= f.password_field :password,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" %>
      </div>

      <div>
        <%= f.submit "Sign up",
            class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg shadow-md transition" %>
      </div>
    <% end %>

    <div class="text-center mt-6">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
